# ─── SMTP (email du formulaire de contact) ────────────────────────────────────
# Exemples compatibles : smtp.gmail.com / smtp.ionos.fr / mail.infomaniak.com / smtp.ovh.net
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="ton.adresse@gmail.com"
SMTP_PASS="mot_de_passe_application"

# ─── API Express ──────────────────────────────────────────────────────────────
# Port du serveur Express (les formulaires envoient ici via proxy Vite)
API_PORT="3001"

# ─── Gemini (optionnel — fonctionnalités IA futures) ─────────────────────────
GEMINI_API_KEY="MA_CLE_GEMINI"

# ─── Production ───────────────────────────────────────────────────────────────
APP_URL="https://bi-on.fr"
